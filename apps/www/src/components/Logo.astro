---
/**
 * EdgeVault logo lockup — the vault mark + live "EdgeVault" wordmark, rendered as
 * text (not a baked image) so its size is driven by the shared --logo-size token
 * and stays identical to the console TopBar. The mark uses the same 32-viewBox
 * geometry as favicon.svg and the console VaultMark.
 *
 *   variant="light" (default) — dark ink text + relay-violet keyway (light grounds)
 *   variant="dark"            — white text + plaintext-lilac keyway (dark grounds)
 */
interface Props {
  variant?: 'light' | 'dark'
}
const { variant = 'light' } = Astro.props
---

<span class="logo" class:list={[variant]} aria-label="EdgeVault">
  <svg class="mark" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
    <path d="M4 4 H20 L28 12 V28 H4 Z" fill="none" stroke="currentColor" stroke-width="3" />
    <path d="M20 4 V12 H28" fill="none" stroke="currentColor" stroke-width="3" />
    <rect x="12" y="16" width="8" height="3" fill="var(--logo-keyway)" />
  </svg>
  <span class="word">EdgeVault</span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .logo.light {
    color: var(--color-body-ink);
    --logo-keyway: var(--color-relay);
  }
  .logo.dark {
    color: #ffffff;
    --logo-keyway: var(--color-plaintext);
  }
  .mark {
    width: var(--logo-mark-size);
    height: var(--logo-mark-size);
    display: block;
    flex: none;
  }
  .word {
    font-family: var(--heading-font-family);
    font-size: var(--logo-size);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: currentColor;
  }
</style>
