{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edgevault-console",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "routes": [{ "pattern": "console.edgevault.io", "custom_domain": true }],
  "vars": {
    "ENVIRONMENT": "production",
    // Public api base for browser WebSocket connections (BFF proxies HTTP).
    "API_WS_BASE": "wss://api.edgevault.io"
  },
  // BFF: the console SSR worker proxies to auth + api via service bindings, so
  // the browser only talks to the console origin (no CORS / cross-site cookies).
  // SSO/SAML live in auth; SCIM lives in api — both reached via AUTH/API_SERVICE.
  "services": [
    { "binding": "AUTH_SERVICE", "service": "edgevault-auth" },
    { "binding": "API_SERVICE", "service": "edgevault-api" },
    { "binding": "BILLING_SERVICE", "service": "edgevault-control-plane" }
  ],
  "env": {
    "staging": {
      "routes": [{ "pattern": "console-staging.edgevault.io", "custom_domain": true }],
      "vars": {
        "ENVIRONMENT": "staging",
        "API_WS_BASE": "wss://api-staging.edgevault.io"
      },
      "services": [
        { "binding": "AUTH_SERVICE", "service": "edgevault-auth-staging" },
        { "binding": "API_SERVICE", "service": "edgevault-api-staging" },
        { "binding": "BILLING_SERVICE", "service": "edgevault-control-plane-staging" }
      ]
    }
  }
}
