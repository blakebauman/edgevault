{
  // Test-only config for vitest-pool-workers. Identical to wrangler.jsonc EXCEPT
  // it omits the remote-only bindings (ai, vectorize) that have no local
  // emulation and force the pool into a remote proxy session — which needs
  // `wrangler login` and so fails in CI. The one test that uses AI (agent.test)
  // tolerates its absence (falls back). Production bindings live in wrangler.jsonc.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edgevault-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "test",
    "SERVICE_NAME": "edgevault-api",
    "AUTH_ISSUER": "https://auth.test",
    "CONSOLE_URL": "https://app.test",
    "EMBEDDING_MODEL": "@cf/baai/bge-base-en-v1.5",
    "TEXT_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "AI_GATEWAY_ID": ""
  },
  "kv_namespaces": [
    { "binding": "CONFIGS_CACHE", "id": "test_configs_cache" },
    { "binding": "ENVIRONMENT_API_KEYS", "id": "test_env_api_keys" }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "WORKSPACE", "class_name": "VaultDurableObject" },
      { "name": "AGENT", "class_name": "EdgeVaultAgent" },
      { "name": "SHARE", "class_name": "ShareDurableObject" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["VaultDurableObject"] },
    { "tag": "v2", "new_sqlite_classes": ["EdgeVaultAgent"] },
    { "tag": "v3", "new_sqlite_classes": ["ShareDurableObject"] }
  ],
  "workflows": [
    {
      "name": "edgevault-promotion",
      "binding": "PROMOTION_WORKFLOW",
      "class_name": "PromotionWorkflow"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "test_hyperdrive",
      "localConnectionString": "postgresql://user:password@localhost:5432/edgevault"
    }
  ],
  "services": [{ "binding": "AUTH_SERVICE", "service": "edgevault-auth" }],
  "queues": {
    "producers": [
      { "queue": "edgevault-audit", "binding": "AUDIT_QUEUE" },
      { "queue": "edgevault-notify", "binding": "NOTIFY_QUEUE" }
    ]
  },
  "r2_buckets": [{ "binding": "AUDIT_BUCKET", "bucket_name": "edgevault-audit" }]
}
