# Neon Local (docker-compose.yml) — control-plane credentials.
# Get the API key at https://console.neon.tech/app/settings/api-keys
# Project ID is under project Settings → General (project: edgevault).

NEON_API_KEY=
NEON_PROJECT_ID=fancy-moon-43340682

# Optional: branch the ephemeral local DB from a specific parent. Leave blank
# to use the staging branch (br-bold-river-a6pz154a, the compose default).
NEON_PARENT_BRANCH_ID=

# Optional: set to `false` to persist the branch across `db:down` (useful if
# you want the same working data across sessions).
DELETE_BRANCH=true
