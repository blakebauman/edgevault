{
  "name": "edgevault",
  "version": "0.0.0",
  "private": true,
  "description": "EdgeVault — edge-native configuration, secrets, and feature-flag platform on Cloudflare",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "lsof -ti:8800-8807,9300-9305 | xargs kill -9 2>/dev/null || true",
    "dev": "turbo run dev",
    "deploy": "turbo run deploy",
    "db:up": "docker compose up -d --wait neon-local",
    "db:down": "docker compose down",
    "db:migrate:local": "DATABASE_URL='postgres://neon:npg@localhost:5432/neondb?sslmode=no-verify' pnpm --filter @edgevault/database db:migrate",
    "db:seed:local": "DATABASE_URL='postgres://neon:npg@localhost:5432/neondb?sslmode=no-verify' pnpm --filter @edgevault/database db:seed",
    "seed:dev": "node scripts/seed-dev.mjs",
    "seed:local": "pnpm db:seed:local && pnpm seed:dev",
    "lint": "biome lint .",
    "boundary": "node scripts/check-boundary.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "cf-typegen": "turbo run cf-typegen",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@edgevault/typescript-config": "workspace:*",
    "lefthook": "^2.1.9",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "wrangler": "^4.98.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "lefthook",
      "sharp",
      "workerd"
    ]
  }
}
