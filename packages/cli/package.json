{
  "name": "@edgevault/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "EdgeVault CLI — inject configs, flags, and secrets into any process",
  "bin": {
    "edgevault": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/bin.ts --bundle --platform=node --target=node20 --format=esm --banner:js=\"#!/usr/bin/env node\" --outfile=dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@edgevault/typescript-config": "workspace:*",
    "@types/node": "^22.18.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  }
}
